.container {
  min-height: 100vh;
  background: #f5f5f5;
}

.loading-container,
.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 40rpx;
}

.loading-icon,
.error-icon {
  font-size: 80rpx;
  margin-bottom: 30rpx;
}

.loading-text {
  font-size: 32rpx;
  color: #666;
}

.error-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.error-desc {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.error-list {
  font-size: 26rpx;
  color: #999;
  line-height: 1.8;
  text-align: left;
  width: 100%;
  padding: 0 40rpx;
  margin-bottom: 40rpx;
}

.retry-btn {
  background: #1890ff;
  color: #fff;
  border-radius: 8rpx;
  font-size: 30rpx;
  padding: 20rpx 60rpx;
}