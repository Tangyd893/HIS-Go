# .env - 环境变量配置（生产环境务必修改所有默认密码）
# ⚠️ 此文件不应提交到版本仓库

# PostgreSQL
POSTGRES_USER=his_admin
POSTGRES_PASSWORD=change_me_123

# Redis
REDIS_PASSWORD=change_me_456

# RabbitMQ
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=change_me_789

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_012

# Nacos
NACOS_AUTH_USERNAME=nacos
NACOS_AUTH_PASSWORD=nacos

# JWT RS256 密钥对（生成方式：openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem）
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
