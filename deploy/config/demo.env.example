# HIS-Go 演示环境变量
# 复制: cp deploy/config/demo.env.example deploy/config/demo.env
# 使用: docker compose --env-file deploy/config/demo.env ...

# ========== 数据库配置 ==========
POSTGRES_USER=his_admin
POSTGRES_PASSWORD=change_me_123

# ========== Redis 配置 ==========
REDIS_PASSWORD=change_me_456

# ========== RabbitMQ 配置 (仅管理端演示需要) ==========
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=change_me_789

# ========== JWT 配置 ==========
# 演示阶段可使用简化模式，留空即可
# 生产环境请配置 RS256 密钥对
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# ========== 演示域名配置 ==========
# 云服务器部署时配置
# DEMO_DOMAIN=his-demo.example.com

# ========== 小程序配置 ==========
# 患者端 H5 地址 (小程序 web-view 加载)
# DEFAULT_PATIENT_H5=https://his-demo.example.com/patient/

# ========== 就诊助手 (RAG + DeepSeek) 配置 ==========
# 配置步骤:
#   1. 复制本文件: cp deploy/config/demo.env.example deploy/config/demo.env
#   2. 填入下方 Key，并将 TRIAGE_RAG_ENABLED 改为 true
#   3. 本地开发: 重启 scripts/start-patient.bat 中的 Outpatient 窗口
#   4. Docker 演示: docker compose -f deploy/compose/demo-patient.yml --env-file deploy/config/demo.env up -d --build his-outpatient
#   5. (可选) 用 SiliconFlow Key 重建嵌入: make triage-embed
#
# DeepSeek Chat API（用于生成挂号建议）
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
# SiliconFlow BGE-M3 嵌入 API（make triage-embed 离线构建 + 运行时语义检索）
SILICONFLOW_API_KEY=sk-your-siliconflow-key
SILICONFLOW_EMBED_MODEL=BAAI/bge-m3
# 就诊助手开关（false 时降级为关键词模式，仍可用；true 且 Key 有效时启用 AI）
TRIAGE_RAG_ENABLED=false
TRIAGE_TOP_K=5

# ========== 其他配置 ==========
# MinIO (演示阶段不启用)
# MINIO_ROOT_USER=minioadmin
# MINIO_ROOT_PASSWORD=change_me_012
