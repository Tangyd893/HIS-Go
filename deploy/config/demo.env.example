# HIS-Go 演示环境变量
# 复制: cp deploy/config/demo.env.example deploy/config/demo.env
# 使用: docker compose --env-file deploy/config/demo.env ...

# ========== 数据库配置 ==========
POSTGRES_USER=his_admin
POSTGRES_PASSWORD=change_me_123

# ========== Redis 配置 ==========
REDIS_PASSWORD=change_me_456

# ========== RabbitMQ 配置 (仅管理端演示需要) ==========
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=change_me_789

# ========== JWT 配置 ==========
# 演示阶段可使用简化模式，留空即可
# 生产环境请配置 RS256 密钥对
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# ========== 演示域名配置 ==========
# 云服务器部署时配置
# DEMO_DOMAIN=his-demo.example.com

# ========== 小程序配置 ==========
# 患者端 H5 地址 (小程序 web-view 加载)
# DEFAULT_PATIENT_H5=https://his-demo.example.com/patient/

# ========== 其他配置 ==========
# MinIO (演示阶段不启用)
# MINIO_ROOT_USER=minioadmin
# MINIO_ROOT_PASSWORD=change_me_012
